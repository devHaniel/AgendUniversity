<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AgendUniversity</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/FrontEnd.styles.css" asp-append-version="true" />
    <style>
    :root {
        --primary: #0d6efd;
        --primary-dark: #084298;
        --soft-blue: #eef5ff;
        --text-dark: #172033;
        --text-muted: #667085;
    }

    body {
        min-height: 100vh;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        background:
            radial-gradient(circle at top left, #dceaff 0, transparent 35%),
            linear-gradient(135deg, #f8fbff 0%, #eef5ff 100%);
        color: var(--text-dark);
    }

    .navbar {
        background-color: rgba(255, 255, 255, 0.92) !important;
        backdrop-filter: blur(10px);
        box-shadow: 0 8px 30px rgba(13, 110, 253, 0.08);
        padding: 14px 0;
    }

    .navbar-brand {
        font-weight: 800;
        color: var(--primary) !important;
    }

    .navbar-nav .nav-link {
        color: #344054 !important;
        font-weight: 500;
        margin-left: 18px;
    }

    .navbar-nav .nav-link:hover,
    .navbar-nav .nav-link.active {
        color: var(--primary) !important;
    }

    .container {
        max-width: 1100px;
        margin-top: 45px;
        margin-bottom: 40px;
    }

    footer {
        text-align: center;
        padding: 25px;
        color: #667085;
        font-size: 0.9rem;
    }

    .landing-hero {
        background: rgba(255, 255, 255, 0.86);
        border-radius: 28px;
        padding: 55px;
        box-shadow: 0 25px 70px rgba(13, 110, 253, 0.14);
    }

    .hero-title {
        font-size: 3rem;
        line-height: 1.1;
        font-weight: 800;
        color: var(--text-dark);
        max-width: 520px;
    }

    .hero-text {
        color: var(--text-muted);
        font-size: 1.12rem;
        margin-top: 18px;
        max-width: 500px;
    }

    .hero-card {
        background: linear-gradient(135deg, #0d6efd, #6ea8fe);
        border-radius: 28px;
        padding: 28px;
        min-height: 360px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .app-window {
        background: white;
        border-radius: 22px;
        width: 100%;
        max-width: 460px;
        overflow: hidden;
        box-shadow: 0 25px 50px rgba(0, 0, 0, 0.16);
    }

    .window-header {
        height: 46px;
        background: #f1f6ff;
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 0 18px;
    }

    .window-header span {
        width: 11px;
        height: 11px;
        border-radius: 50%;
        background: #0d6efd;
        opacity: .45;
    }

    .window-body {
        display: flex;
        padding: 22px;
        gap: 20px;
    }

    .mini-sidebar {
        width: 70px;
        background: #eef5ff;
        border-radius: 16px;
        padding: 14px;
    }

    .mini-sidebar div {
        height: 12px;
        background: #0d6efd;
        border-radius: 20px;
        margin-bottom: 14px;
        opacity: .55;
    }

    .mini-content {
        flex: 1;
    }

    .mini-content h5 {
        font-weight: 700;
        margin-bottom: 18px;
    }

    .subject-card {
        background: #f8fbff;
        border: 1px solid #d9e8ff;
        border-radius: 15px;
        padding: 14px;
        margin-bottom: 12px;
    }

    .subject-card small {
        display: block;
        color: var(--text-muted);
    }

    .progress-box {
        margin-top: 18px;
        color: var(--text-muted);
        font-size: .9rem;
    }

    .features-section {
        margin-top: 35px;
    }

    .feature-card {
        height: 100%;
        background: white;
        border-radius: 22px;
        padding: 30px;
        box-shadow: 0 14px 35px rgba(13, 110, 253, 0.08);
        border: 1px solid #e5efff;
    }

    .feature-icon {
        font-size: 2rem;
        margin-bottom: 15px;
    }

    .feature-card h5 {
        font-weight: 700;
        color: var(--text-dark);
    }

    .feature-card p {
        color: var(--text-muted);
        margin-bottom: 0;
    }

    @@media (max-width: 768px) {
        .landing-hero {
            padding: 32px;
        }

        .hero-title {
            font-size: 2.2rem;
        }

        .container {
            max-width: 94%;
        }
    }
</style>
</head>
<body class="d-flex flex-column">
    <header>
        <nav class="navbar navbar-expand-sm navbar-light">
            <div class="container-fluid px-4">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <span style="color: #667eea; font-weight: 700;">📚 AgendUniversity</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-end">
                    <ul class="navbar-nav">
                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["Controller"].ToString() == "Home" ? "active" : "")" 
                               asp-area="" asp-controller="Home" asp-action="Index">Inicio</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["Controller"].ToString() == "Auth" && ViewContext.RouteData.Values["Action"].ToString() == "Login" ? "active" : "")" 
                               asp-area="" asp-controller="Auth" asp-action="Login">Iniciar Sesión</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["Controller"].ToString() == "Auth" && ViewContext.RouteData.Values["Action"].ToString() == "Register" ? "active" : "")" 
                               asp-area="" asp-controller="Auth" asp-action="Register">Registrarse</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer>
        <div>
            &copy; 2026 - AgendUniversity | <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacidad</a>
        </div>
    </footer>
    
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
