@using FrontEnd.Enums
@model List<FrontEnd.Models.Tarea.Tarea>

@{
    ViewData["Title"] = "Tareas";

    string ClaseEstado(int estado) => estado switch
    {
        (int)TareaEnum.Faltante => "text-bg-warning text-dark",
        (int)TareaEnum.Pendiente => "text-bg-info",
        (int)TareaEnum.Entregado => "text-bg-success",
        _ => "text-bg-secondary"
    };
}

<div class="container-fluid">
    <div class="row mb-4 mt-3">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <h1>
                    <i class="bi bi-check-circle"></i>
                    Mis Tareas
                </h1>
                <a asp-action="Create" 
                   asp-route-returnUrl="@Url.Action("Index", "Tareas")"
                   class="btn btn-primary">
                    <i class="bi bi-plus-lg"></i>
                    Nueva Tarea
                </a>
            </div>
        </div>
    </div>

    @if (Model.Any())
    {
        <div class="card">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr class="table-light">
                                <th>Título</th>
                                <th>Asignatura</th>
                                <th>Estado</th>
                                <th>Fecha Entrega</th>
                                <th>Nota / Calificación</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var tarea in Model)
                            {
                                var diasRestantes = (tarea.FechaEntrega - DateTime.Now).Days;
                                var rowClass = diasRestantes < 0 ? "table-danger" : diasRestantes <= 3 ? "table-warning" : "";
                                
                                <tr class="@rowClass">
                                    <td>
                                        <a asp-action="Details" asp-route-id="@tarea.Id" class="link-primary fw-bold">
                                            @tarea.Titulo
                                        </a>
                                    </td>
                                    <td>
                                        @if (tarea.Asignatura != null)
                                        {
                                            <a asp-controller="Asignaturas" asp-action="Details" asp-route-id="@tarea.Asignatura.Id" class="link-secondary">
                                                @tarea.Asignatura.Nombre
                                            </a>
                                        }
                                        else
                                        {
                                            <span class="text-muted">Sin asignar</span>
                                        }
                                    </td>
                                    <td>
                                        <span class="badge @ClaseEstado(tarea.Estado)">
                                            @(((TareaEnum)tarea.Estado).ToString())
                                        </span>
                                    </td>
                                    <td>
                                        <span class="@(diasRestantes < 0 ? "text-danger fw-bold" : "")">
                                            @tarea.FechaEntrega.ToString("dd/MM/yyyy")
                                            @if (diasRestantes < 0)
                                            {
                                                <span class="badge bg-danger ms-1">Vencida</span>
                                            }
                                            else if (diasRestantes <= 3)
                                            {
                                                <span class="badge bg-warning text-dark ms-1">Próxima</span>
                                            }
                                        </span>
                                    </td>
                                    <td>
                                        @if (tarea.Nota > 0)
                                        {
                                            <span class="@(tarea.Nota >= tarea.Calificacion * 0.6m ? "text-success" : "text-danger")">
                                                @tarea.Nota / @tarea.Calificacion
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td>
                                        <div class="btn-group btn-group-sm" role="group">
                                            <a asp-action="Details" asp-route-id="@tarea.Id" class="btn btn-outline-info" title="Ver detalles">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                            <a asp-action="Edit" asp-route-id="@tarea.Id" class="btn btn-outline-primary" title="Editar">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            <button type="button" class="btn btn-outline-danger" data-bs-toggle="modal"
                                                    data-bs-target="#deleteModal" data-id="@tarea.Id" data-nombre="@tarea.Titulo"
                                                    title="Eliminar">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-info text-center" role="alert">
            <i class="bi bi-info-circle"></i>
            <strong>No hay tareas disponibles.</strong>
            <p>Crea tu primera tarea para comenzar a organizarte.</p>
            <a asp-action="Create" class="btn btn-primary btn-sm">
                <i class="bi bi-plus-lg"></i>
                Nueva Tarea
            </a>
        </div>
    }
</div>

<!-- Modal de Confirmación de Eliminación -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h1 class="modal-title fs-5" id="deleteModalLabel">Confirmar Eliminación</h1>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p>¿Estás seguro de que deseas eliminar la tarea <strong id="tareaNombreMostrar"></strong>?</p>
                <p class="text-muted">Esta acción no se puede deshacer.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <form method="post" asp-action="Delete" style="display:inline;">
                    <input type="hidden" id="deleteId" name="id" />
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-trash"></i>
                        Eliminar
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const deleteModal = document.getElementById('deleteModal');
        deleteModal.addEventListener('show.bs.modal', function (event) {
            const button = event.relatedTarget;
            const id = button.getAttribute('data-id');
            const nombre = button.getAttribute('data-nombre');
            
            document.getElementById('deleteId').value = id;
            document.getElementById('tareaNombreMostrar').textContent = nombre;
        });
    </script>
}