@using FrontEnd.Enums
@model FrontEnd.Models.PagedResult<FrontEnd.Models.Tarea.Tarea>

@{
    ViewData["Title"] = "Tareas";
    var currentPage = Model.Page < 1 ? 1 : Model.Page;
    var totalPages = Model.TotalPages < 1 ? 1 : Model.TotalPages;
    var hasPreviousPage = currentPage > 1;
    var hasNextPage = currentPage < totalPages;

    string ClaseEstado(int estado) => estado switch
    {
        (int)AsignaturaEnum.Aprobada => "text-bg-success",
        (int)AsignaturaEnum.Reprobada => "text-bg-danger",
        (int)AsignaturaEnum.Cursando => "text-bg-warning text-dark",
        _ => "text-bg-secondary"
    };
}

<h1>Tareas</h1>

<hr />

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <a asp-action="Create" 
           asp-route-returnUrl="@Url.Action("Index", "Tareas", new { page = currentPage, pageSize = Model.PageSize })"
           class="btn btn-primary">
            Nueva Tarea
        </a>
    </div>
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <div>
            <i class="bi bi-check2-square"></i>
            Listado de Tareas
        </div>

        <div>
            <span class="badge text-bg-primary">
                N° @Model.TotalItems
            </span>
        </div>
    </div>

    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0 align-middle">
                <thead>
                    <tr>
                        <th>Título</th>
                        <th>Asignatura</th>
                        <th>Estado</th>
                        <th>Fecha Creación</th>
                        <th>Fecha Entrega</th>
                        <th>Calificación</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Items.Any())
                    {
                        @foreach (var tarea in Model.Items)
                        {
                            <tr>
                                <td>
                                    <a asp-action="Details" asp-route-id="@tarea.Id" class="link-primary fw-bold">
                                        @tarea.Titulo
                                    </a>
                                </td>
                                <td>
                                    @if (tarea.Asignatura != null)
                                    {
                                        <a asp-controller="Asignaturas" asp-action="Details" asp-route-asignaturaId="@tarea.Asignatura.Id" class="link-secondary">
                                            @tarea.Asignatura.Nombre
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="text-muted">Sin asignar</span>
                                    }
                                </td>
                                <td>
                                    <span class="badge @ClaseEstado(tarea.Estado)">
                                        @(((TareaEnum)tarea.Estado).ToString())
                                    </span>
                                </td>
                                <td>@tarea.FechaCreacion.ToString("dd/MM/yyyy")</td>
                                <td>@tarea.FechaEntrega.ToString("dd/MM/yyyy")</td>
                                <td>
                                    @if (tarea.Nota > 0)
                                    {
                                        <span>@tarea.Nota / @tarea.Calificacion</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td>
                                    <a asp-action="Edit"
                                       asp-route-id="@tarea.Id"
                                       asp-route-returnUrl="@Url.Action("Index", "Tareas", new { page = currentPage, pageSize = Model.PageSize })"
                                       class="btn btn-outline-primary btn-sm">
                                        <i class="bi bi-pencil"></i>
                                        Editar
                                    </a>
                                    <button type="button" class="btn btn-outline-danger btn-sm" data-bs-toggle="modal"
                                            data-bs-target="#deleteModal" data-id="@tarea.Id" data-nombre="@tarea.Titulo">
                                        <i class="bi bi-trash"></i>
                                        Eliminar
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center">No hay tareas disponibles.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<nav class="mt-3" aria-label="Paginación de tareas">
    <ul class="pagination justify-content-center">
        <li class="page-item @(!hasPreviousPage ? "disabled" : "")">
            <a class="page-link"
               asp-action="Index"
               asp-route-page="@(currentPage - 1)"
               asp-route-pageSize="@Model.PageSize">
                Anterior
            </a>
        </li>

        @for (var pageNumber = 1; pageNumber <= totalPages; pageNumber++)
        {
            <li class="page-item @(pageNumber == currentPage ? "active" : "")">
                <a class="page-link"
                   asp-action="Index"
                   asp-route-page="@pageNumber"
                   asp-route-pageSize="@Model.PageSize">
                    @pageNumber
                </a>
            </li>
        }

        <li class="page-item @(!hasNextPage ? "disabled" : "")">
            <a class="page-link"
               asp-action="Index"
               asp-route-page="@(currentPage + 1)"
               asp-route-pageSize="@Model.PageSize">
                Siguiente
            </a>
        </li>
    </ul>
</nav>

<!-- Modal de Confirmación de Eliminación -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h1 class="modal-title fs-5" id="deleteModalLabel">Confirmar Eliminación</h1>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p>¿Estás seguro de que deseas eliminar la tarea <strong id="tareaNombreMostrar"></strong>?</p>
                <p class="text-muted">Esta acción no se puede deshacer.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <form method="post" asp-action="Delete" style="display:inline;">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="returnUrl" value="@Url.Action("Index", "Tareas", new { page = currentPage, pageSize = Model.PageSize })" />
                    <input type="hidden" id="deleteId" name="id" />
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-trash"></i>
                        Eliminar
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const deleteModal = document.getElementById('deleteModal');
        deleteModal.addEventListener('show.bs.modal', function (event) {
            const button = event.relatedTarget;
            const id = button.getAttribute('data-id');
            const nombre = button.getAttribute('data-nombre');
            
            document.getElementById('deleteId').value = id;
            document.getElementById('tareaNombreMostrar').textContent = nombre;
        });
    </script>
}
