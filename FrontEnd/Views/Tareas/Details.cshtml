@using FrontEnd.Enums
@model FrontEnd.Models.Tarea.Tarea

@{
    ViewData["Title"] = "Detalles de Tarea";

    string ClaseEstado(int estado) => estado switch
    {
        (int)AsignaturaEnum.Aprobada => "text-bg-success",
        (int)AsignaturaEnum.Reprobada => "text-bg-danger",
        (int)AsignaturaEnum.Cursando => "text-bg-warning text-dark",
        _ => "text-bg-secondary"
    };

    var diasRestantes = (Model.FechaEntrega - DateTime.Now).Days;
    string claseFecha = diasRestantes < 0 ? "text-danger" : 
                        diasRestantes == 0 ? "text-warning" : 
                        diasRestantes <= 3 ? "text-warning" : "text-success";

    string TamanoArchivo(long bytes)
    {
        if (bytes >= 1024 * 1024)
            return $"{bytes / 1024m / 1024m:0.##} MB";

        if (bytes >= 1024)
            return $"{bytes / 1024m:0.##} KB";

        return $"{bytes} B";
    }
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-12">
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left"></i>
                Volver
            </a>
        </div>
    </div>

    <div class="row">
        <div class="col-md-8">
            <div class="card mb-4">
                <div class="card-header">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <i class="bi bi-check-circle"></i>
                            <span>@Model.Titulo</span>
                        </div>
                        <div>
                            <span class="badge @ClaseEstado(Model.Estado)">
                                @(((TareaEnum)Model.Estado).ToString())
                            </span>
                        </div>
                    </div>
                </div>
                <div class="card-body">
                    <h5 class="card-title">@Model.Titulo</h5>
                    
                    <div class="mb-3">
                        <h6 class="text-muted">Descripción</h6>
                        <p class="card-text">
                            @if (string.IsNullOrEmpty(Model.Descripcion))
                            {
                                <span class="text-muted fst-italic">Sin descripción</span>
                            }
                            else
                            {
                                @Model.Descripcion
                            }
                        </p>
                    </div>

                    <hr />

                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <h6 class="text-muted">Asignatura</h6>
                                <p class="fw-bold">
                                    @if (Model.Asignatura != null)
                                    {
                                        <a asp-controller="Asignaturas" asp-action="Details" asp-route-asignaturaId="@Model.Asignatura.Id" class="link-primary">
                                            @Model.Asignatura.Nombre
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="text-muted">Sin asignar</span>
                                    }
                                </p>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <h6 class="text-muted">Estado</h6>
                                <p>
                                    <span class="badge @ClaseEstado(Model.Estado)">
                                        @(((TareaEnum)Model.Estado).ToString())
                                    </span>
                                </p>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <h6 class="text-muted">Fecha de Creación</h6>
                                <p class="fw-bold">@Model.FechaCreacion.ToString("dd/MM/yyyy HH:mm")</p>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <h6 class="text-muted">Fecha de Entrega</h6>
                                <p class="fw-bold @claseFecha">
                                    @Model.FechaEntrega.ToString("dd/MM/yyyy")
                                    @if (diasRestantes < 0)
                                    {
                                        <span class="badge bg-danger ms-2">Atrasada por @(-diasRestantes) días</span>
                                    }
                                    else if (diasRestantes == 0)
                                    {
                                        <span class="badge bg-warning text-dark ms-2">Hoy</span>
                                    }
                                    else if (diasRestantes <= 3)
                                    {
                                        <span class="badge bg-warning text-dark ms-2">En @diasRestantes días</span>
                                    }
                                </p>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <h6 class="text-muted">Calificación Máxima</h6>
                                <p class="fw-bold">@Model.Calificacion</p>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <h6 class="text-muted">Nota Obtenida</h6>
                                <p class="fw-bold">
                                    @if (Model.Nota > 0)
                                    {
                                        <span class="@(Model.Nota >=  Model.Calificacion * 0.6m ? "text-success" : "text-danger")">
                                            @Model.Nota / @Model.Calificacion
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">Sin calificar</span>
                                    }
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="card-footer text-body-secondary">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary btn-sm"
                            asp-route-returnUrl="@Url.Action("Details", "Tareas")">
                                <i class="bi bi-pencil"></i>
                                Editar
                            </a>
                        </div>
                        <div>
                            <button type="button" class="btn btn-outline-danger btn-sm" data-bs-toggle="modal"
                                    data-bs-target="#deleteModal" data-id="@Model.Id"
                                    data-nombre="@Model.Titulo">
                                <i class="bi bi-trash"></i>
                                Eliminar
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card mb-4">
                <div class="card-header">
                    <i class="bi bi-paperclip"></i>
                    Subir Archivo
                </div>
                <div class="card-body">
                    <form asp-action="SubirArchivo" asp-route-id="@Model.Id" method="post" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()
                        <div class="mb-3">
                            <input type="file" name="archivo" class="form-control" />
                        </div>
                        <button type="submit" class="btn btn-primary btn-sm">
                            <i class="bi bi-upload"></i>
                            Subir
                        </button>
                    </form>
                </div>
            </div>

            <div class="card mb-4">
                <div class="card-header">
                    <i class="bi bi-info-circle"></i>
                    Información Rápida
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <small class="text-muted d-block">ID de la Tarea</small>
                        <code>@Model.Id</code>
                    </div>
                    <div class="mb-3">
                        <small class="text-muted d-block">Porcentaje</small>
                        <div class="progress">
                            @{
                                var porcentaje = Model.Calificacion > 0 ? (int)((Model.Nota / Model.Calificacion) * 100) : 0;
                                var claseBarra = porcentaje >= 60 ? "bg-success" : "bg-warning";
                            }
                            <div class="progress-bar @claseBarra" role="progressbar" style="width: @porcentaje%" aria-valuenow="@porcentaje" aria-valuemin="0" aria-valuemax="100">
                                @porcentaje%
                            </div>
                        </div>
                    </div>
                    <div class="mb-3">
                        <small class="text-muted d-block">Días Restantes</small>
                        <p class="@claseFecha fw-bold">
                            @if (diasRestantes < 0)
                            {
                                <span>Vencida hace @(-diasRestantes) días</span>
                            }
                            else if (diasRestantes == 0)
                            {
                                <span>Vence hoy</span>
                            }
                            else
                            {
                                <span>@diasRestantes días</span>
                            }
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <div>
                <i class="bi bi-folder2-open"></i>
                Archivos
            </div>
            <span class="badge text-bg-primary">
                N° @(Model.Archivos?.Count ?? 0)
            </span>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0 align-middle">
                    <thead>
                        <tr>
                            <th>Nombre</th>
                            <th>Tipo</th>
                            <th>Tamaño</th>
                            <th>Fecha Subida</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Archivos != null && Model.Archivos.Any())
                        {
                            @foreach (var archivo in Model.Archivos)
                            {
                                <tr>
                                    <td class="fw-bold">@archivo.NombreOriginal</td>
                                    <td>@archivo.ContentType</td>
                                    <td>@TamanoArchivo(archivo.TamanoBytes)</td>
                                    <td>@archivo.FechaSubida.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>
                                        <a asp-action="DescargarArchivo"
                                           asp-route-id="@archivo.Id"
                                           class="btn btn-outline-primary btn-sm">
                                            <i class="bi bi-download"></i>
                                            Descargar
                                        </a>
                                        <form asp-action="EliminarArchivo" 
                                              asp-route-id="@archivo.Id"
                                              asp-route-tareaId="@Model.Id"
                                              method="post" 
                                              style="display:inline;"
                                              onsubmit="return confirm('¿Estás seguro de que deseas eliminar este archivo?');">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-outline-danger btn-sm">
                                                <i class="bi bi-trash"></i>
                                                Eliminar
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center">No hay archivos subidos.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Modal de Confirmación de Eliminación -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h1 class="modal-title fs-5" id="deleteModalLabel">Confirmar Eliminación</h1>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p>¿Estás seguro de que deseas eliminar la tarea <strong id="tarjaNombreMostrar"></strong>?</p>
                <p class="text-muted">Esta acción no se puede deshacer.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <form method="post" asp-action="Delete" style="display:inline;">
                    <input type="hidden" id="deleteId" name="id" />
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-trash"></i>
                        Eliminar
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const deleteModal = document.getElementById('deleteModal');
        deleteModal.addEventListener('show.bs.modal', function (event) {
            const button = event.relatedTarget;
            const id = button.getAttribute('data-id');
            const nombre = button.getAttribute('data-nombre');
            
            document.getElementById('deleteId').value = id;
            document.getElementById('tarjaNombreMostrar').textContent = nombre;
        });
    </script>
}
