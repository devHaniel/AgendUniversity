@model AsignaturaCreateViewModel

@{
    ViewData["Title"] = "Crear Asignatura";
}

<h1>Crear Asignatura</h1>


<hr />

<div class="card">
    <div class="card-header">
        <i class="bi bi-book"></i>
        Nueva Asignatura
    </div>

    <div class="card-body">
        <form asp-action="Create" method="post">

            <div class="mb-3">
                <label asp-for="Nombre" class="form-label">Nombre de la asignatura</label>
                <input asp-for="Nombre" class="form-control" />
                <span asp-validation-for="Nombre" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="PeriodoId" class="form-label">Periodo</label>
                <select asp-for="PeriodoId"
                        asp-items="Model.Periodos"
                        class="form-select">
                    <option value="">Seleccione un periodo</option>
                </select>
                <span asp-validation-for="PeriodoId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Estado" class="form-label">Estado</label>
                <select asp-for="Estado"
                        asp-items="Model.Estados"
                        class="form-select">
                    <option value="">Seleccione un estado</option>
                </select>
                <span asp-validation-for="Estado" class="text-danger"></span>
            </div>

            <div class="d-flex justify-content-end gap-2">
                <a asp-action="Index" class="btn btn-outline-secondary">
                    Cancelar
                </a>

                <button type="submit" class="btn btn-primary">
                    Guardar
                </button>
            </div>

        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    
}