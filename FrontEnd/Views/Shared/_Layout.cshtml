<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FrontEnd</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/FrontEnd.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
</head>

<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom box-shadow">
            <div class="container-fluid">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index"><i
                    class="bi bi-backpack text-primary"><span> </span></i>AgendUniversity</a>

                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                            data-bs-target=".navbar-collapse">
                        <span class="navbar-toggler-icon"></span>
                    </button>

                    <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                        <ul class="navbar-nav ms-auto">
                            <li class="nav-item">
                                <form asp-action="Logout" asp-controller="Auth" method="post">
                                    <button type="submit" class="nav-link btn btn-link text-dark">
                                        Salir
                                    </button>
                                </form>
                            </li>
                        </ul>
                    </div>
                </div>
            </nav>
        </header>

        <div class="d-flex">
            <!-- Sidebar -->
            <aside class="d-flex flex-column flex-shrink-0 p-3 bg-light border-end min-vh-100" style="width: 260px;">

                <ul class="nav nav-pills flex-column mb-auto">
                    <li>
                        <a asp-controller="Dashboard" asp-action="Index"
                           class="nav-link link-dark @(ViewContext.RouteData.Values["Controller"].ToString() == "Dashboard" ? "active text-white" : "")">
                            Dashboard
                        </a>
                    </li>
                    <li>
                        <a asp-controller="Periodos" asp-action="Index"
                           class="nav-link link-dark @(ViewContext.RouteData.Values["Controller"].ToString() == "Periodos" ? "active text-white" : "")">
                            Periodos
                        </a>
                    </li>
                    <li>
                        <a asp-controller="Asignaturas" asp-action="Index"
                           class="nav-link link-dark @(ViewContext.RouteData.Values["Controller"].ToString() == "Asignaturas" ? "active text-white" : "")">
                            Asignaturas
                        </a>
                    </li>
                    <li>
                        <a asp-controller="Tareas" asp-action="Index"
                           class="nav-link link-dark @(ViewContext.RouteData.Values["Controller"].ToString() == "Tareas" ? "active text-white" : "")">
                            Tareas
                        </a>
                    </li>
                </ul>
            </aside>

            <!-- Contenido principal -->
            <main role="main" class="flex-grow-1 p-4">
                @RenderBody()
            </main>
        </div>

        <script src="~/lib/jquery/dist/jquery.min.js"></script>
        <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
        <script src="~/js/site.js" asp-append-version="true"></script>
        <script src="sidebars.js"></script>
        @await RenderSectionAsync("Scripts", required: false)
        @if (TempData["Mensaje"] != null)
        {
            <div class="toast-container position-fixed top-0 end-0 p-3" style="z-index: 9999;">

                <div id="liveToast" class="toast text-bg-success border-0" role="alert" aria-live="assertive"
                     aria-atomic="true">

                    <div class="d-flex">
                        <div class="toast-body">
                            <i class="bi bi-check-circle-fill me-2"></i>
                            @TempData["Mensaje"]
                        </div>

                        <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"
                                aria-label="Close">
                        </button>
                    </div>

                </div>
            </div>

            <script>
                document.addEventListener('DOMContentLoaded', function () {

                const toastEl =
                document.getElementById('liveToast');

                if (toastEl) {
                const toast =
                new bootstrap.Toast(toastEl, {
                delay: 4000
                });

                toast.show();
                }

                });
            </script>
        }
    </body>

</html>
