@using FrontEnd.Enums
@model DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
    string ClaseEstado(int estado) => estado switch
    {
        (int)AsignaturaEnum.Aprobada => "text-bg-success",
        (int)AsignaturaEnum.Reprobada => "text-bg-danger",
        (int)AsignaturaEnum.Cursando => "text-bg-warning text-dark",
        _ => "text-bg-secondary"
    };
}

<h1>Dashboard</h1>

<hr />

<div class="card mb-4">
    <div class="card-header">
        <i class="bi bi-calendar-event"></i>
        Periodo Actual
    </div>
    <div class="card-body">
        @if (Model.Periodo != null)
        {
            <H5> <a class="link-opacity-100" asp-controller="Periodos" asp-action="Details"
                    asp-route-id="@Model.Periodo.Id">
                @Model.Periodo.Nombre
            </a>
        </H5>
        <p>Fecha Inicio: @Model.Periodo.FechaInicio.ToShortDateString()</p>
        <p>Fecha Fin: @Model.Periodo.FechaFin.ToShortDateString()</p>
    }
        else
    {
        <p>No hay un periodo activo actualmente.</p>
    }
</div>
</div>

<h3>Asignaturas</h3>
<hr />

<div class="row mb-3">
    @if (Model.Asignaturas.Any())
    {
        @foreach (var asignatura in Model.Asignaturas)
        {

            <div class="col-md-4 d-flex">
                <div class="card mb-4 w-100">
                    <div class="card-header">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <i class="bi bi-calendar-event me-2"></i>
                                <a class="link-opacity-100" asp-controller="Asignaturas" asp-action="Details"
                                   asp-route-asignaturaId="@asignatura.Id">
                                    @asignatura.Nombre
                                </a>
                            </div>

                            <span class="badge @ClaseEstado(asignatura.Estado)">
                                @(((AsignaturaEnum)asignatura.Estado).ToString())
                            </span>
                        </div>
                    </div>

                    <div class="card-body d-flex flex-column">
                        <h5>@asignatura.Nombre </h5>
                        <p class="flex-grow-1">
                            Calificación: @asignatura.TotalNota/@asignatura.TotalCalificaciones
                        </p>
                    </div>

                    <div class="card-footer text-body-secondary">
                        <div class="d-flex justify-content-between align-items-center">
                            <a asp-action="Edit" asp-route-id="@asignatura.Id" class="btn btn-outline-primary btn-sm">
                                <i class="bi bi-pencil"></i>
                                Editar
                            </a>

                            <button type="button" class="btn btn-outline-danger btn-sm" data-bs-toggle="modal"
                                    data-bs-target="#deleteModal" data-id="@asignatura.Id" data-nombre="@asignatura.Nombre">
                                <i class="bi bi-trash"></i>
                                Eliminar
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="col-12">
            <div class="alert alert-light border text-center text-muted">
                No hay asignaturas registradas.
            </div>
        </div>
    }
</div>

<h3>Tareas pendientes</h3>
<hr />

<div class="row mb-3">
    @if (Model.Tareas.Any())
    {
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-header bg-white">
                    <i class="bi bi-list-check text-primary me-1"></i>
                    Tareas pendientes
                </div>

                <div class="card-body p-0">
                    <table class="table table-hover mb-0 align-middle">
                        <thead>
                            <tr>
                                <th>Tarea</th>
                                <th>Asignatura</th>
                                <th>Fecha entrega</th>
                                <th>Estado</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var tarea in Model.Tareas)
                            {
                                <tr>
                                    <td><a asp-action="Details" asp-route-id="@tarea.Id" asp-controller="Tareas"
                                           class="link-primary fw-bold">
                                        @tarea.Titulo
                                    </a>
                                </td>
                                <td>@(tarea.Asignatura?.Nombre ?? "Sin asignatura")</td>
                                <td>@tarea.FechaEntrega.ToShortDateString()</td>
                                <td>
                                    <span class="badge text-bg-warning text-dark">
                                        Pendiente
                                    </span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
    else
{
    <div class="col-12">
        <div class="alert alert-light border text-center text-muted">
            No hay tareas pendientes.
        </div>
    </div>
}
</div>