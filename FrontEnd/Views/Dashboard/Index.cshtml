@using FrontEnd.Enums
@model DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
     string ClaseEstado(int estado) => estado switch
    {
        (int)AsignaturaEnum.Aprobada => "text-bg-success",
        (int)AsignaturaEnum.Reprobada => "text-bg-danger",
        (int)AsignaturaEnum.Cursando => "text-bg-warning text-dark",
        _ => "text-bg-secondary"
    };
}

<h1>Dashboard</h1>

<hr />

<div class="card mb-4">
    <div class="card-header">
        <i class="bi bi-calendar-event"></i>
        Periodo Actual
    </div>
    <div class="card-body">
        @if (Model.Periodo != null)
        {
            <h5>@Model.Periodo.Nombre</h5>
            <p>Fecha Inicio: @Model.Periodo.FechaInicio.ToShortDateString()</p>
            <p>Fecha Fin: @Model.Periodo.FechaFin.ToShortDateString()</p>
        }
        else
        {
            <p>No hay un periodo activo actualmente.</p>
        }
    </div>
</div>

<h3>Asignaturas</h3>
<hr />

<div class="row mb-3">
    @if (Model.Asignaturas.Any())
    {
        @foreach (var asignatura in Model.Asignaturas)
        {
            <div class="col-md-4 col-lg-3 mb-2">
                <div class="card mb-3 shadow-sm h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <div>
                                <i class="bi bi-book text-primary me-1"></i>
                                <a class="fw-semibold text-decoration-none"
                                   asp-controller="Asignaturas"
                                   asp-action="Details"
                                   asp-route-asignaturaId="@asignatura.Id">
                                    @asignatura.Nombre
                                </a>
                            </div>

                            <span class="badge @ClaseEstado(asignatura.Estado)">
                                @(((AsignaturaEnum)asignatura.Estado).ToString())
                            </span>
                        </div>

                        <p class="mb-3">
                            <strong>Tareas:</strong> @asignatura.Tareas.Count()
                        </p>

                        <div class="d-flex gap-2">
                            <a asp-controller="Asignaturas"
                               asp-action="Edit"
                               asp-route-id="@asignatura.Id"
                               class="btn btn-outline-primary btn-sm flex-fill">
                                <i class="bi bi-pencil"></i>
                                Editar
                            </a>

                            <button type="button"
                                    class="btn btn-outline-danger btn-sm flex-fill"
                                    data-id="@asignatura.Id"
                                    data-nombre="@asignatura.Nombre"
                                    data-bs-toggle="modal"
                                    data-bs-target="#deleteModal">
                                <i class="bi bi-trash"></i>
                                Eliminar
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="col-12">
            <div class="alert alert-light border text-center text-muted">
                No hay asignaturas registradas.
            </div>
        </div>
    }
</div>

<h3>Tareas pendientes</h3>
<hr />

<div class="row mb-3">
    @if (Model.Tareas.Any())
    {
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-header bg-white">
                    <i class="bi bi-list-check text-primary me-1"></i>
                    Tareas pendientes
                </div>

                <div class="card-body p-0">
                    <table class="table table-hover mb-0 align-middle">
                        <thead>
                            <tr>
                                <th>Tarea</th>
                                <th>Asignatura</th>
                                <th>Fecha entrega</th>
                                <th>Estado</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var tarea in Model.Tareas)
                            {
                                <tr>
                                    <td>@tarea.Titulo</td>
                                    <td>@(tarea.Asignatura?.Nombre ?? "Sin asignatura")</td>
                                    <td>@tarea.FechaEntrega.ToShortDateString()</td>
                                    <td>
                                        <span class="badge text-bg-warning text-dark">
                                            Pendiente
                                        </span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="col-12">
            <div class="alert alert-light border text-center text-muted">
                No hay tareas pendientes.
            </div>
        </div>
    }
</div>