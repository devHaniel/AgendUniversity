@model List<FrontEnd.Models.Periodo.Periodo>
@{
    ViewData["Title"] = "Periodos";

    string ClaseEstado(string estado) => estado switch
    {
        "En curso" => "text-bg-success",
        "Finalizado" => "text-bg-danger",
        "No iniciado" => "text-bg-warning text-dark",
        _ => "text-bg-secondary"
    };

}

<h1>Periodos</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Crear Nuevo Periodo</a>
</p>


@foreach (var grupoAnio in Model
    .GroupBy(p => p.FechaInicio.Year)
    .OrderByDescending(g => g.Key))
{
    <div class="d-flex align-items-center mt-4 mb-3">
        <h3 class="me-3 mb-0">@grupoAnio.Key</h3>
        <hr class="flex-grow-1" />
    </div>

    <div class="row">
        @foreach (var periodo in grupoAnio.OrderByDescending(p => p.FechaInicio))
        {
            <div class="col-md-4">
                <div class="card mb-4">
                    <div class="card-header">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <i class="bi bi-calendar-event me-2"></i>
                                <a class="link-opacity-100"
                                   asp-action="Details"
                                   asp-route-id="@periodo.Id">
                                    @periodo.Nombre
                                </a>
                            </div>

                            <span class="badge @ClaseEstado(periodo.EstadoPeriodo)">
                                @periodo.EstadoPeriodo
                            </span>
                        </div>
                    </div>

                    <div class="card-body">
                        <h5>@periodo.Nombre </h5>
                        <p>Fecha Inicio: @periodo.FechaInicio.ToShortDateString()</p>
                        <p>Fecha Fin: @periodo.FechaFin.ToShortDateString()</p>
                    </div>

                    <div class="card-footer text-body-secondary">
                        <div class="d-flex justify-content-between align-items-center">
                            <a asp-action="Edit"
                               asp-route-id="@periodo.Id"
                               class="btn btn-outline-primary btn-sm">
                                <i class="bi bi-pencil"></i>
                                Editar
                            </a>

                            <button type="button"
                                    class="btn btn-outline-danger btn-sm"
                                    data-bs-toggle="modal"
                                    data-bs-target="#deleteModal"
                                    data-id="@periodo.Id"
                                    data-nombre="@periodo.Nombre">
                                <i class="bi bi-trash"></i>
                                Eliminar
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

<!-- Modal de Confirmación de Eliminación -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="deleteModalLabel">Confirmar Eliminación</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                ¿Estás seguro de que deseas eliminar el período <strong id="periodoNombre"></strong>?
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <form id="deleteForm" method="post" style="display: inline;">
                    <button type="submit" class="btn btn-danger">Eliminar</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const deleteModal = document.getElementById('deleteModal');
        deleteModal.addEventListener('show.bs.modal', function (event) {
            const button = event.relatedTarget;
            const periodoId = button.getAttribute('data-id');
            const periodoNombre = button.getAttribute('data-nombre');

            document.getElementById('periodoNombre').textContent = periodoNombre;

            const deleteForm = document.getElementById('deleteForm');
            deleteForm.action = '@Url.Action("Delete", "Periodos")/' + periodoId;
        });
    </script>
}
